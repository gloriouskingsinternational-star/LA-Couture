APP_NAME="L.A. Couture"
APP_ENV=production
APP_KEY=                            # Run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://YOUR_APP.up.railway.app

BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database (Supabase PostgreSQL) ──────────────────────────
# Get these from: Supabase Dashboard → Project → Settings → Database
DB_CONNECTION=pgsql
DB_HOST=db.YOUR_PROJECT_REF.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD
DB_SSLMODE=require

# ── Admin Seeder Password ────────────────────────────────────
# The password for admin@lacouture.com (set before first deploy)
ADMIN_PASSWORD=YourStrongPassword@2026!

# ── CORS / Frontend URL ──────────────────────────────────────
# Set this to your Netlify site URL (no trailing slash)
FRONTEND_URL=https://YOUR_SITE.netlify.app
SANCTUM_STATEFUL_DOMAINS=YOUR_SITE.netlify.app

SESSION_DRIVER=cookie
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=none

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@lacouture.com"
MAIL_FROM_NAME="L.A. Couture"
